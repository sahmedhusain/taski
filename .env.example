# Server runtime configurations
PORT=8080
ENVIRONMENT=development

# Database configuration
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=todo
DB_SSLMODE=disable

# Security configurations
# Generate with: openssl rand -base64 32
# REQUIRED in production - the backend refuses to start without a unique, high-entropy value here.
JWT_SECRET=replace_with_a_long_random_generated_secret
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# pgAdmin (local DB inspection UI, bound to 127.0.0.1 only) - change for anything beyond local dev
PGADMIN_EMAIL=admin@taski.com
PGADMIN_PASSWORD=admin
